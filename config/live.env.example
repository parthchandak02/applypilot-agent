# Live apply configuration — enable only after dry-run validation
# Merge into ~/.applypilot/.env when ready

APPLY_DRY_RUN=false
APPLY_MIN_SCORE=7
APPLY_MAX_WORKERS=2
APPLY_LIMIT=5
AGENT_PROVIDER=cursor-sdk
APPLY_AGENT_MODEL=composer-2.5

# Hermes cron schedules (weekdays):
#   job-apply-discover: 0 7 * * 1-5
#   job-apply-submit:   0 9,17 * * 1-5
