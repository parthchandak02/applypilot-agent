# ApplyPilot-Cursor Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Provider for stages 1-5 (pick one)
GEMINI_API_KEY=
# OPENAI_API_KEY=
# LLM_URL=http://127.0.0.1:8080/v1
# LLM_MODEL=gemini-2.0-flash

# Stage 6 — Cursor Agent (default)
CURSOR_API_KEY=
AGENT_PROVIDER=cursor-sdk
APPLY_AGENT_MODEL=composer-2.5

# Safety gates (flip APPLY_DRY_RUN=false only after 10 successful dry-runs)
APPLY_DRY_RUN=true
APPLY_MIN_SCORE=7
APPLY_MAX_WORKERS=2
APPLY_LIMIT=5

# Optional
CAPSOLVER_API_KEY=
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# APPLYPILOT_DIR=~/.applypilot

# Legacy Claude Code provider (set AGENT_PROVIDER=claude)
# Requires claude CLI on PATH — not needed for cursor-sdk
